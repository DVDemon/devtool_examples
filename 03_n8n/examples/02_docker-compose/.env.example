# Скопируйте в .env и подставьте значения.
# N8N_ENCRYPTION_KEY — обязательно уникальная длинная строка; не менять после создания credentials.

N8N_ENCRYPTION_KEY=replace_with_random_string_at_least_32_characters_long

# Базовый URL для формирования ссылок на webhook (локальная разработка)
WEBHOOK_URL=http://localhost:5678/

TZ=Europe/Moscow

# Только для docker-compose.postgres.yml
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change_me
POSTGRES_DB=n8n
DB_POSTGRESDB_HOST=postgres
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=n8n
DB_POSTGRESDB_PASSWORD=change_me
