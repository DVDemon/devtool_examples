# Скопируйте в .env рядом с docker-compose.yml этого примера.

# --- n8n (SQLite по умолчанию, данные в Docker volume n8n_data) ---
N8N_ENCRYPTION_KEY=replace_with_random_string_at_least_32_characters_long
WEBHOOK_URL=http://localhost:5678/
TZ=Europe/Moscow

# PostgreSQL + pgvector только для RAG (сервис rag-postgres)
RAG_POSTGRES_USER=rag
RAG_POSTGRES_PASSWORD=change_me_rag_db
RAG_POSTGRES_DB=rag

# Модель эмбеддингов в Ollama (сервис ollama-pull-embed при первом старте)
# См. https://ollama.com/library — например nomic-embed-text (768 измерений), all-minilm (384)
OLLAMA_EMBED_MODEL=nomic-embed-text
